{
  "name": "Saucedemo_POM_Automation",
  "version": "1.0.0",
  "description": "Playwright POM automation suite for saucedemo.com - robust, deterministic, multi-browser.",
  "main": "playwright.config.js",
  "scripts": {
    "test": "npx playwright test",
    "test:parallel": "npx playwright test --workers=2",
    "test:sequential": "npx playwright test --workers=1",
